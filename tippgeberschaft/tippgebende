        .footer-section p { color: var(--black); font-size: 0.95rem; margin-bottom: 0.5rem; }
        .footer-social-icons { display: flex; gap: 1rem; margin-top: 1rem; }
        .footer-social-icon { width: 40px; height: 40px; background: var(--white); border-radius: 8px; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s; color: var(--primary-blue); font-size: 1.1rem; font-weight: 700; }
        .footer-social-icon:hover { background: var(--primary-blue); color: var(--white); transform: translateY(-3px); }
        .footer-bottom { text-align: center; padding-top: 2rem; border-top: 1px solid rgba(0,0,0,0.1); color: var(--black); opacity: 0.8; font-size: 0.9rem; }

        @media (max-width: 968px) {
