        .praemien-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
        .praemien-kachel { background: var(--white); border-radius: 18px; padding: 2rem; border: 2px solid transparent; transition: all 0.3s; }
        .praemien-kachel:hover { border-color: var(--page-color); transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,98,177,0.1); }
        .praemien-kachel-type { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--medium-gray); margin-bottom: 0.5rem; }
        .praemien-kachel h3 { font-size: 1.1rem; font-weight: 700; color: var(--black); margin-bottom: 0.4rem; }
        .praemien-betrag { font-size: 2.8rem; font-weight: 800; color: var(--page-color); line-height: 1; margin: 0.8rem 0; }
        .praemien-spende-line { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--green); font-weight: 600; margin-bottom: 1rem; }
