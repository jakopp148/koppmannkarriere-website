        .btn-multi { display: inline-flex; align-items: center; gap: 0.5rem; padding: 1rem 1.8rem; background: var(--white); color: var(--dark-blue); font-size: 0.95rem; font-weight: 700; border-radius: 50px; text-decoration: none; white-space: nowrap; transition: all 0.3s; }
        .btn-multi:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.2); }

        /* CTA */
        .cta-strip { padding: 4.5rem 2rem; background: var(--page-color); text-align: center; }
        .cta-strip h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; color: var(--white); margin-bottom: 0.8rem; }
        .cta-strip p { font-size: 1rem; color: rgba(255,255,255,0.78); margin-bottom: 2rem; }
        .btn-white { display: inline-block; padding: 1rem 2.5rem; background: var(--white); color: var(--page-color); font-size: 1rem; font-weight: 700; border-radius: 50px; text-decoration: none; transition: all 0.3s; box-shadow: 0 6px 20px rgba(0,0,0,0.15); }
        .btn-white:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(0,0,0,0.2); }

        /* FOOTER */
        footer { background: var(--light-blue); padding: 4rem 2rem 2rem; }
        .footer-container { max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: repeat(4,1fr); gap: 3rem; margin-bottom: 3rem; }
        .footer-section h3 { font-size: 1.1rem; font-weight: 700; color: var(--black); margin-bottom: 1.5rem; }
