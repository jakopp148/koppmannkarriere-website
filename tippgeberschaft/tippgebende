        .header-cta-btn { display: inline-block; padding: 0.65rem 1.6rem; background: transparent; color: var(--white); font-size: 0.9rem; font-weight: 600; border: 2px solid rgba(255,255,255,0.6); border-radius: 50px; cursor: pointer; transition: all 0.3s; text-decoration: none; white-space: nowrap; }
