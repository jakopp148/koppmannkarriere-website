<script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
    const header = document.getElementById('header');
    window.addEventListener('scroll', () => { header.classList.toggle('scrolled', window.scrollY > 50); });

    const sections = document.querySelectorAll('section[id]');
    const anchorBtns = document.querySelectorAll('.anchor-btn');
    window.addEventListener('scroll', () => {
        let current = '';
        sections.forEach(sec => { if (window.scrollY >= sec.offsetTop - 160) current = sec.id; });
        anchorBtns.forEach(btn => btn.classList.toggle('active', btn.dataset.target === current));
    });
    anchorBtns.forEach(btn => {
        btn.addEventListener('click', () => { document.getElementById(btn.dataset.target)?.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
    });

    // FAQ Accordion
    document.querySelectorAll('.faq-question').forEach(btn => {
        btn.addEventListener('click', () => {
            const item = btn.parentElement;
            const answer = item.querySelector('.faq-answer');
            const isOpen = item.classList.contains('open');
            document.querySelectorAll('.faq-item').forEach(i => {
                i.classList.remove('open');
                i.querySelector('.faq-answer').style.maxHeight = '0';
            });
            if (!isOpen) {
                item.classList.add('open');
                answer.style.maxHeight = answer.scrollHeight + 'px';
            }
        });
    });

    // Mailto Builder
    document.getElementById('send-btn').addEventListener('click', () => {
        const name = document.getElementById('f-name').value.trim();
        const email = document.getElementById('f-email').value.trim();
        const type = document.getElementById('f-type').value;
        const hinweis = document.getElementById('f-hinweis').value.trim();
        if (!name || !email) { alert('Bitte Name und E-Mail-Adresse angeben.'); return; }
        const subject = encodeURIComponent('Tippgeber-Hinweis: ' + name);
        const body = encodeURIComponent(
            'Hallo Jan,\n\n' +
            'ich möchte einen Tippgeber-Hinweis abgeben.\n\n' +
            'Mein Name: ' + name + '\n' +
            'Meine E-Mail: ' + email + '\n' +
            'Art der Empfehlung: ' + type + '\n' +
            (hinweis ? 'Hinweis: ' + hinweis + '\n' : '') +
            '\nViele Grüße,\n' + name
        );
        window.location.href = 'mailto:jan@koppmannkarriere.de?subject=' + subject + '&body=' + body;
    });
</script>
