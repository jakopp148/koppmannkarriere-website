        .formular-info h3 { font-size: 1.1rem; font-weight: 700; color: var(--black); margin-bottom: 1rem; }
        .formular-info p { font-size: 0.95rem; color: var(--medium-gray); line-height: 1.8; margin-bottom: 1rem; }
        .formular-info ul { list-style: none; padding: 0; }
        .formular-info ul li { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.9rem; color: var(--medium-gray); padding: 0.4rem 0; }
        .formular-info ul li::before { content: '✓'; color: var(--page-color); font-weight: 800; flex-shrink: 0; }

        .formular-card { background: var(--light-gray); border-radius: 20px; padding: 2.5rem; }
        .formular-card h3 { font-size: 1.1rem; font-weight: 700; color: var(--black); margin-bottom: 0.4rem; }
        .formular-card > p { font-size: 0.88rem; color: var(--medium-gray); margin-bottom: 2rem; }
        .f-field { margin-bottom: 1.2rem; }
        .f-label { font-size: 0.82rem; font-weight: 700; color: var(--medium-gray); display: block; margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em; }
        .f-input { width: 100%; padding: 0.8rem 1rem; border: 2px solid #e5e7eb; border-radius: 10px; font-family: 'Montserrat', sans-serif; font-size: 0.95rem; background: var(--white); outline: none; transition: border-color 0.2s; }
        .f-input:focus { border-color: var(--page-color); }
        .f-select { width: 100%; padding: 0.8rem 1rem; border: 2px solid #e5e7eb; border-radius: 10px; font-family: 'Montserrat', sans-serif; font-size: 0.95rem; background: var(--white); outline: none; cursor: pointer; }
        .f-select:focus { border-color: var(--page-color); }
        .f-textarea { width: 100%; padding: 0.8rem 1rem; border: 2px solid #e5e7eb; border-radius: 10px; font-family: 'Montserrat', sans-serif; font-size: 0.95rem; background: var(--white); outline: none; resize: vertical; min-height: 80px; transition: border-color 0.2s; }
        .f-textarea:focus { border-color: var(--page-color); }
        .f-note { font-size: 0.78rem; color: var(--medium-gray); margin-top: 0.3rem; line-height: 1.5; }
        .btn-submit { display: block; width: 100%; padding: 1.1rem; background: var(--page-color); color: var(--white); font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 700; border: none; border-radius: 12px; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 16px rgba(0,98,177,0.25); margin-top: 1.5rem; }
        .btn-submit:hover { background: var(--dark-blue); transform: translateY(-2px); }

        /* FAQ */
        #sec-faq { background: var(--light-gray); }
        .faq-list { display: flex; flex-direction: column; gap: 0; border: 2px solid #e5e7eb; border-radius: 16px; overflow: hidden; }
